// -----------------------------------------------------------------------------
// PRISMA CONFIGURATION
// -----------------------------------------------------------------------------
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// -----------------------------------------------------------------------------
// AUTH & HIERARCHY (RBAC)
// -----------------------------------------------------------------------------

enum Role {
  MASTER
  GERENTE
  DISCIPULADOR
}

model User {
  id              String   @id @default(uuid())
  name            String
  email           String   @unique
  password        String   // Stores the hashed password
  role            Role     @default(DISCIPULADOR)

  // Stores the public name of the group managed by this user
  guildaName      String?
  // Stores the selected faction symbol for the group
  guildaIcon      String?  

  // HIERARCHY: Self-referencing relationship
  reportsToId     String?
  reportsTo       User?    @relation("ManagementChain", fields: [reportsToId], references: [id])
  subordinates    User[]   @relation("ManagementChain")

  // OWNERSHIP
  managedValentes Valente[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// -----------------------------------------------------------------------------
// CORE ENTITY: VALENTE
// -----------------------------------------------------------------------------

model Valente {
  id          String   @id @default(uuid())
  name        String
  image       String?  // Nullable, used for avatar displays
  totalXP     Int      @default(0)
  level       Int      @default(1)
  structure   String   // e.g., "GAD", "IMS", "LOUVOR"
  description String?  @db.Text 

  // Relationship to the managing User
  userId      String
  managedBy   User     @relation(fields: [userId], references: [id])

  // --- RELATIONSHIP: PROGRESSION & RANK SYSTEM ---
  // Connects the hero to their current dynamic rank from the Patente table
  patenteId   String?
  patente     Patente? @relation(fields: [patenteId], references: [id])

  // Stat Relationships
  attributes    Attributes?
  loveLanguages LoveLanguages?
  
  // Spirit Engine
  holyPower      HolyPower[]
  fastingLogs    FastingLog[]

  // Companheiros & Quests
  friendIds         String[] @default([]) 
  trackedMissionIds String[] @default([])

  // Many-to-Many Relations
  reliquias    ValenteReliquia[] 
  missions     ValenteMission[]
  
  // Audit Trail
  xpLogs       XpLog[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// -----------------------------------------------------------------------------
// ANALYTICS & STATS
// -----------------------------------------------------------------------------

model Attributes {
  id           String  @id @default(uuid())
  forca        Int     @default(1)
  destreza     Int     @default(1)
  constituicao Int     @default(1)
  inteligencia Int     @default(1)
  sabedoria    Int     @default(1)
  carisma      Int     @default(1)

  valenteId    String  @unique
  valente      Valente @relation(fields: [valenteId], references: [id], onDelete: Cascade)
}

model LoveLanguages {
  id        String  @id @default(uuid())
  palavras  Int     @default(0)
  servico   Int     @default(0)
  presentes Int     @default(0)
  tempo     Int     @default(0)
  toque     Int     @default(0)

  valenteId String  @unique
  valente   Valente @relation(fields: [valenteId], references: [id], onDelete: Cascade)
}

model HolyPower {
  id                String    @id @default(uuid())
  name              String    
  current           Int       @default(0)
  goal              Int       @default(30)
  streak            Int       @default(0)
  
  lastStreakUpdate  DateTime? 
  isResetDaily      Boolean   @default(true) 
  updatedAt         DateTime  @default(now()) @updatedAt

  valenteId String
  valente   Valente @relation(fields: [valenteId], references: [id], onDelete: Cascade)
}

model FastingLog {
  id          String   @id @default(uuid())
  valenteId   String
  valente     Valente  @relation(fields: [valenteId], references: [id], onDelete: Cascade)
  type        String   
  duration    Int      
  date        DateTime @default(now())
  notes       String?  @db.Text 
  
  @@index([valenteId])
}

// -----------------------------------------------------------------------------
// GAMEPLAY MECHANICS
// -----------------------------------------------------------------------------

model Reliquia {
  id          String         @id @default(uuid())
  name        String
  description String
  icon        String         
  rarity      String         
  
  triggerType String         
  ruleParams  Json           
  
  createdAt   DateTime       @default(now())
  valentes    ValenteReliquia[]
}

model ValenteReliquia {
  valenteId  String
  reliquiaId String
  awardedAt  DateTime @default(now())

  valente    Valente  @relation(fields: [valenteId], references: [id], onDelete: Cascade)
  reliquia   Reliquia @relation(fields: [reliquiaId], references: [id], onDelete: Cascade)

  @@id([valenteId, reliquiaId])
}

model Mission {
  id                String           @id @default(uuid())
  title             String
  description       String           @db.Text
  xpReward          Int
  type              String           
  
  triggerType       String           @default("MANUAL")
  targetValue       Int              @default(0)
  targetHabit       String?          

  rewardAttribute   String?          
  rewardAttribute2  String?          
  rewardAttrValue   Int              @default(0)
  
  periodicity       String           @default("NONE") 
  expiresAt         DateTime?

  createdAt         DateTime         @default(now())
  valentes          ValenteMission[]
}

model ValenteMission {
  id          String   @id @default(uuid())
  valenteId   String
  missionId   String
  status      String   @default("ACTIVE") 
  createdAt   DateTime @default(now()) 
  completedAt DateTime?

  valente     Valente   @relation(fields: [valenteId], references: [id], onDelete: Cascade)
  mission     Mission   @relation(fields: [missionId], references: [id], onDelete: Cascade)

  @@unique([valenteId, missionId]) 
}

model XpLog {
  id        String   @id @default(uuid())
  valenteId String
  amount    Int      
  reason    String   
  createdAt DateTime @default(now())

  valente   Valente  @relation(fields: [valenteId], references: [id], onDelete: Cascade)
}

// -----------------------------------------------------------------------------
// PROGRESSION & RANK SYSTEM
// -----------------------------------------------------------------------------

model Patente {
  id          String   @id @default(uuid())
  level       Int      @unique 
  title       String   
  xpRequired  Int      
  tierColor   String   
  iconUrl     String   
  
  // Link back to Valentes using this rank
  valentes    Valente[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}