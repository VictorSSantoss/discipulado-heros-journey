// -----------------------------------------------------------------------------
// PRISMA CONFIGURATION
// -----------------------------------------------------------------------------
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// -----------------------------------------------------------------------------
// AUTH & HIERARCHY (RBAC)
// -----------------------------------------------------------------------------

enum Role {
  MASTER
  GERENTE
  DISCIPULADOR
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  password     String   // Stores the hashed password
  role         Role     @default(DISCIPULADOR)

  // HIERARCHY: Self-referencing relationship
  // One-to-Many relationship. A Gerente manages multiple Discipuladores.
  reportsToId  String?
  reportsTo    User?    @relation("ManagementChain", fields: [reportsToId], references: [id])
  subordinates User[]   @relation("ManagementChain")

  // OWNERSHIP: One-to-Many relationship. Heroes managed by a specific user.
  managedValentes Valente[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// -----------------------------------------------------------------------------
// CORE ENTITY: VALENTE
// -----------------------------------------------------------------------------

model Valente {
  id          String   @id @default(uuid())
  name        String
  image       String?  // Nullable, used for avatar displays
  totalXP     Int      @default(0)
  structure   String   // e.g., "GAD", "IMS", "LOUVOR"
  description String?  @db.Text // Historical lore and chronicled feats

  // Relationship to the managing User (One-to-Many)
  userId      String
  managedBy   User     @relation(fields: [userId], references: [id])

  // Stat Relationships
  attributes    Attributes?
  loveLanguages LoveLanguages?
  
  // One-to-Many relationship for tracking spiritual habits and streaks
  holyPower     HolyPower[]

  // --- COMPANHEIROS SYSTEM ---
  // Simple array of IDs to store friend connections efficiently
  friendIds   String[] @default([]) 

  // Many-to-Many Relations
  reliquias   ValenteReliquia[] // REPLACED: medals
  missions    ValenteMission[]
  
  // Audit Trail (One-to-Many)
  xpLogs      XpLog[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// -----------------------------------------------------------------------------
// ANALYTICS & STATS (Profile Progress Data)
// -----------------------------------------------------------------------------

model Attributes {
  id           String  @id @default(uuid())
  forca        Int     @default(0)
  destreza     Int     @default(0)
  constituicao Int     @default(0)
  inteligencia Int     @default(0)
  sabedoria    Int     @default(0)
  carisma      Int     @default(0)

  // One-to-One relationship with Valente
  valenteId    String  @unique
  valente      Valente @relation(fields: [valenteId], references: [id], onDelete: Cascade)
}

model LoveLanguages {
  id        String  @id @default(uuid())
  palavras  Int     @default(0)
  servico   Int     @default(0)
  presentes Int     @default(0)
  tempo     Int     @default(0)
  toque     Int     @default(0)

  // One-to-One relationship with Valente
  valenteId String  @unique
  valente   Valente @relation(fields: [valenteId], references: [id], onDelete: Cascade)
}

model HolyPower {
  id        String  @id @default(uuid())
  name      String  // Identifies the specific power (Oração, Leitura, etc.)
  current   Int     @default(0)
  goal      Int     @default(30)
  streak    Int     @default(0)

  // One-to-Many relationship with Valente
  valenteId String
  valente   Valente @relation(fields: [valenteId], references: [id], onDelete: Cascade)
}

// -----------------------------------------------------------------------------
// GAMEPLAY MECHANICS (Relics, Achievements & Progression)
// -----------------------------------------------------------------------------

model Reliquia {
  id          String         @id @default(uuid())
  name        String
  description String
  icon        String         // Storage path for the SVG/Image asset
  rarity      String         // e.g., "COMMON", "RARE", "LEGENDARY"
  
  // DYNAMIC RULES ENGINE
  triggerType String         // e.g., "XP_MILESTONE", "HABIT_STREAK", "MISSION_COUNT", "MANUAL"
  ruleParams  Json           // JSON box holding the exact criteria (e.g., {"habit": "Jejum", "streak": 21})
  
  createdAt   DateTime       @default(now())

  // Many-to-Many relationship through the join table
  valentes    ValenteReliquia[]
}

model ValenteReliquia {
  valenteId  String
  reliquiaId String
  awardedAt  DateTime @default(now())

  valente    Valente  @relation(fields: [valenteId], references: [id], onDelete: Cascade)
  reliquia   Reliquia @relation(fields: [reliquiaId], references: [id], onDelete: Cascade)

  @@id([valenteId, reliquiaId])
}

model Mission {
  id          String           @id @default(uuid())
  title       String
  description String           @db.Text
  xpReward    Int
  type        String           // Mission categorization (HABIT, EVENT, TASK)
  createdAt   DateTime         @default(now())

  // Many-to-Many relationship through the join table
  valentes    ValenteMission[]
}

model ValenteMission {
  id          String    @id @default(uuid())
  valenteId   String
  missionId   String
  status      String    @default("ACTIVE") 
  createdAt   DateTime  @default(now()) 
  completedAt DateTime?

  valente     Valente   @relation(fields: [valenteId], references: [id], onDelete: Cascade)
  mission     Mission   @relation(fields: [missionId], references: [id], onDelete: Cascade)

  @@unique([valenteId, missionId]) 
}

// -----------------------------------------------------------------------------
// AUDIT SYSTEM (Transaction Tracking)
// -----------------------------------------------------------------------------

model XpLog {
  id        String   @id @default(uuid())
  valenteId String
  amount    Int      // Numerical change to totalXP
  reason    String   
  createdAt DateTime @default(now())

  // One-to-Many relationship with Valente
  valente   Valente  @relation(fields: [valenteId], references: [id], onDelete: Cascade)
}